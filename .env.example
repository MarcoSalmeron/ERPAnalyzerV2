# Copy this file to .env and fill in real values. Never commit .env.

# OpenAI / LLM provider
OPENAI_API_KEY=your-openai-api-key-here

# PostgreSQL (pgvector) connection string
# Example: postgresql://user:password@localhost:5432/vectordb
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/vectordb

# Comma-separated list of origins allowed to call the API (CORS).
# Use explicit origins in production; do NOT use "*".
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend (Vite) — base URLs for the backend
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
